#!/usr/bin/env bash
# r2d2 — CLI del plugin R2D2-Harness
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
case "${1:-}" in
  init) shift; exec "$SCRIPT_DIR/r2d2-init.sh" init "$@" ;;
  *)
    echo "Uso: r2d2 init --name <nombre> --path <directorio> [--force] [--git-init] [--full]"
    echo ""
    echo "  --full   Modo completo: copia docker/, docs/, product/, tests/, init scripts."
    echo "           Por defecto solo crea specs/, progress/ y archivos de tracking."
    exit 1
    ;;
esac
